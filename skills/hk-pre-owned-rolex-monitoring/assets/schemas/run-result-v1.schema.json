{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hk-pre-owned-rolex-monitoring.local/schemas/run-result-v1.schema.json",
  "title": "HK Pre-owned Rolex Monitoring Run Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "ok", "operation", "status", "skill_version",
    "monitor_id", "run_id", "state_modified", "result", "warnings", "error"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "ok": {"type": "boolean"},
    "operation": {"type": "string", "minLength": 1},
    "status": {
      "enum": ["BASELINE_CREATED", "CHANGED", "NO_CHANGE", "SKIPPED_DUPLICATE", "INVALID", "ERROR"]
    },
    "skill_version": {"type": "string", "minLength": 1},
    "monitor_id": {"type": ["string", "null"]},
    "run_id": {"type": ["string", "null"]},
    "state_modified": {"type": "boolean"},
    "result": {"type": "object"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "error": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": {"type": "string"},
            "message": {"type": "string"},
            "details": {"type": "object"}
          }
        }
      ]
    }
  }
}
