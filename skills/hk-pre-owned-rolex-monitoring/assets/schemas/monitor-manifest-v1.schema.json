{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hk-pre-owned-rolex-monitoring.local/schemas/monitor-manifest-v1.schema.json",
  "title": "HK Pre-owned Rolex Monitoring Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "monitor_id", "display_name", "target"],
  "properties": {
    "schema_version": {"const": 1},
    "monitor_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "display_name": {"type": "string", "minLength": 1},
    "enabled": {"type": "boolean", "default": true},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter", "url"],
      "properties": {
        "adapter": {"type": "string", "minLength": 1},
        "url": {"type": "string", "minLength": 1},
        "fixture_path": {"type": ["string", "null"]}
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timezone": {"type": "string", "default": "UTC"},
        "jobs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "cron"],
            "properties": {
              "role": {"type": "string", "minLength": 1},
              "cron": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "notification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {"type": "string", "default": "runtime-default"},
        "recipient": {"type": "string", "default": "current-user"},
        "send_no_change_report": {"type": "boolean", "default": true},
        "include_images": {"type": "boolean", "default": true}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseline_samples": {"type": "integer", "minimum": 2, "maximum": 5, "default": 2},
        "change_confirmation_samples": {"type": "integer", "minimum": 2, "maximum": 5, "default": 2},
        "suspicious_confirmation_samples": {"type": "integer", "minimum": 3, "maximum": 5, "default": 3},
        "sample_interval_seconds": {"type": "number", "minimum": 0, "maximum": 3600, "default": 5},
        "retry_delays_seconds": {
          "type": "array",
          "items": {"type": "integer", "minimum": 0},
          "default": [120, 300, 600]
        },
        "suspicious_absolute_change": {"type": "integer", "minimum": 1, "default": 5},
        "suspicious_percentage_change": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 100,
          "default": 10
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "storage_backend": {"const": "sqlite", "default": "sqlite"},
        "image_cache": {"type": "boolean", "default": true},
        "backup_enabled": {"type": "boolean", "default": true}
      }
    }
  }
}
